# Copy this file to .dev.vars and fill in the values
# .dev.vars is gitignored and used by wrangler pages dev for local secrets

# Supabase (server-side secrets)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (public vars — also needed by SvelteKit for browser client)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Replicate
REPLICATE_API_TOKEN=r8_your-token
REPLICATE_USERNAME=your-username
REPLICATE_WEBHOOK_SIGNING_KEY=your-signing-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_SUCCESS_URL=http://localhost:8788/app/billing?topup=success
STRIPE_CANCEL_URL=http://localhost:8788/app/billing?topup=cancel

# R2
PUBLIC_R2_URL=http://localhost:8788/r2